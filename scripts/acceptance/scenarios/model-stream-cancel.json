{
  "version": 1,
  "name": "real-model-stream-cancel-recovery",
  "app_path": "../../../../dist/recomphamr.exe",
  "workspace": "../../../../.acceptance-fixture",
  "artifact_directory": "../../../../artifacts/tui-acceptance/model-stream-cancel",
  "debug_log": ".rehamr/log.txt",
  "terminal": {
    "columns": 100,
    "rows": 30
  },
  "steps": [
    { "type": "launch", "label": "launch application", "timeout_seconds": 20 },
    { "type": "wait_event", "label": "wait for debug session", "category": "session", "minimum": 2, "timeout_seconds": 20 },
    { "type": "type_text", "label": "enter first model request", "text": "Reply with exactly READY." },
    { "type": "key", "label": "submit first model request", "key": "enter" },
    { "type": "wait_event", "label": "wait for first request", "category": "request", "minimum": 1, "timeout_seconds": 60 },
    { "type": "screenshot", "label": "capture active first turn", "file": "first-turn-active.png" },
    { "type": "wait_event", "label": "wait for first assistant", "category": "assistant", "minimum": 1, "timeout_seconds": 300 },
    { "type": "wait_event", "label": "wait for first turn end", "category": "turn_end", "minimum": 1, "timeout_seconds": 30 },
    { "type": "screenshot", "label": "capture completed first turn", "file": "first-turn-complete.png" },
    { "type": "type_text", "label": "enter cancellable request", "text": "Write a long numbered explanation with at least one hundred items." },
    { "type": "key", "label": "submit cancellable request", "key": "enter" },
    { "type": "wait_event", "label": "wait for cancellable request", "category": "request", "minimum": 2, "timeout_seconds": 60 },
    { "type": "sleep", "label": "allow streaming to become visible", "milliseconds": 1000 },
    { "type": "screenshot", "label": "capture active cancellable turn", "file": "before-cancel.png" },
    { "type": "key", "label": "cancel active turn", "key": "ctrl_c" },
    { "type": "wait_event", "label": "wait for cancellation", "category": "cancel", "minimum": 1, "timeout_seconds": 30 },
    { "type": "wait_event", "label": "wait for cancelled turn end", "category": "turn_end", "minimum": 2, "timeout_seconds": 30 },
    { "type": "type_text", "label": "enter recovery request", "text": "Reply with exactly RECOVERED." },
    { "type": "key", "label": "submit recovery request", "key": "enter" },
    { "type": "wait_event", "label": "wait for recovery assistant", "category": "assistant", "minimum": 2, "timeout_seconds": 300 },
    { "type": "wait_event", "label": "wait for recovery turn end", "category": "turn_end", "minimum": 3, "timeout_seconds": 30 },
    { "type": "assert_event_sequence", "label": "verify cancel recovery ordering", "categories": ["cancel", "turn_end", "user", "request", "assistant", "turn_end"] },
    { "type": "screenshot", "label": "capture recovered turn", "file": "recovered.png" },
    { "type": "key", "label": "exit application", "key": "ctrl_d" },
    { "type": "sleep", "label": "allow terminal restoration", "milliseconds": 500 },
    { "type": "type_text", "label": "write shell restoration sentinel", "text": "Set-Content -LiteralPath '.harness-shell-restored' -Value 'restored' -NoNewline" },
    { "type": "key", "label": "execute restoration probe", "key": "enter" },
    { "type": "assert_file", "label": "verify restored shell command", "path": ".harness-shell-restored", "text": "restored", "timeout_seconds": 10 },
    { "type": "remove_file", "label": "remove restoration sentinel", "path": ".harness-shell-restored" },
    { "type": "close_window", "label": "close restored shell", "timeout_seconds": 10 }
  ]
}
