{
  "version": 1,
  "name": "real-model-tool-loop-cancel-recovery",
  "app_path": "../../../../dist/recomphamr.exe",
  "workspace": "../../../../.acceptance-fixture",
  "artifact_directory": "../../../../artifacts/tui-acceptance/agent-tool-loop-cancel",
  "debug_log": ".rehamr/log.txt",
  "terminal": {
    "columns": 100,
    "rows": 30
  },
  "steps": [
    { "type": "launch", "label": "launch application", "timeout_seconds": 20 },
    { "type": "wait_event", "label": "wait for debug session", "category": "session", "minimum": 2, "timeout_seconds": 20 },
    { "type": "type_text", "label": "request ordered fixture tools", "text": "Use tools to perform exactly these four operations in order: write_file path stage-c-one.txt with content ONE; write_file path stage-c-two.txt with content TWO; read_file path stage-c-one.txt; read_file path stage-c-two.txt. After all four succeed, reply exactly TOOLS_OK." },
    { "type": "key", "label": "submit ordered fixture tools", "key": "enter" },
    { "type": "wait_event", "label": "wait for four tool starts", "category": "tool_start", "minimum": 4, "timeout_seconds": 300 },
    { "type": "wait_event", "label": "wait for four paired results", "category": "tool_result", "minimum": 4, "timeout_seconds": 300 },
    { "type": "wait_event", "label": "wait for tool turn end", "category": "turn_end", "minimum": 1, "timeout_seconds": 300 },
    { "type": "assert_event_count", "label": "require exactly four starts", "category": "tool_start", "count": 4 },
    { "type": "assert_event_count", "label": "require exactly four results", "category": "tool_result", "count": 4 },
    { "type": "assert_file", "label": "verify first fixture", "path": "stage-c-one.txt", "text": "ONE", "timeout_seconds": 10 },
    { "type": "assert_file", "label": "verify second fixture", "path": "stage-c-two.txt", "text": "TWO", "timeout_seconds": 10 },
    { "type": "screenshot", "label": "capture completed tool turn", "file": "tools-complete.png" },
    { "type": "type_text", "label": "request cancellable PowerShell", "text": "Call the powershell tool exactly once with this script and do not use any other tool: Start-Sleep -Seconds 120; Set-Content -LiteralPath 'stage-c-must-not-exist.txt' -Value 'STALE' -NoNewline" },
    { "type": "key", "label": "submit cancellable PowerShell", "key": "enter" },
    { "type": "wait_event", "label": "wait for PowerShell start", "category": "tool_start", "minimum": 5, "timeout_seconds": 300 },
    { "type": "screenshot", "label": "capture running PowerShell", "file": "powershell-running.png" },
    { "type": "key", "label": "cancel running PowerShell", "key": "ctrl_c" },
    { "type": "wait_event", "label": "wait for cancellation", "category": "cancel", "minimum": 1, "timeout_seconds": 30 },
    { "type": "wait_event", "label": "wait for cancelled turn end", "category": "turn_end", "minimum": 2, "timeout_seconds": 30 },
    { "type": "sleep", "label": "allow cancelled result delivery", "milliseconds": 1500 },
    { "type": "assert_event_count", "label": "reject cancelled stale result", "category": "tool_result", "count": 4 },
    { "type": "type_text", "label": "enter recovery request", "text": "Reply with exactly RECOVERED." },
    { "type": "key", "label": "submit recovery request", "key": "enter" },
    { "type": "wait_event", "label": "wait for recovery turn end", "category": "turn_end", "minimum": 3, "timeout_seconds": 300 },
    { "type": "assert_event_sequence", "label": "verify tool cancel recovery ordering", "categories": ["tool_start", "tool_result", "turn_end", "tool_start", "cancel", "turn_end", "user", "request", "assistant", "turn_end"] },
    { "type": "assert_event_count", "label": "require no reissued cancelled tool", "category": "tool_start", "count": 5 },
    { "type": "assert_event_count", "label": "require no stale or reissued result", "category": "tool_result", "count": 4 },
    { "type": "assert_file", "label": "verify cancelled script made no file", "path": "stage-c-must-not-exist.txt", "exists": false, "timeout_seconds": 2 },
    { "type": "screenshot", "label": "capture recovered turn", "file": "recovered.png" },
    { "type": "remove_file", "label": "remove first fixture", "path": "stage-c-one.txt" },
    { "type": "remove_file", "label": "remove second fixture", "path": "stage-c-two.txt" },
    { "type": "key", "label": "exit application", "key": "ctrl_d" },
    { "type": "sleep", "label": "allow terminal restoration", "milliseconds": 500 },
    { "type": "type_text", "label": "write shell restoration sentinel", "text": "Set-Content -LiteralPath '.harness-shell-restored' -Value 'restored' -NoNewline" },
    { "type": "key", "label": "execute restoration probe", "key": "enter" },
    { "type": "assert_file", "label": "verify restored shell command", "path": ".harness-shell-restored", "text": "restored", "timeout_seconds": 10 },
    { "type": "remove_file", "label": "remove restoration sentinel", "path": ".harness-shell-restored" },
    { "type": "close_window", "label": "close restored shell", "timeout_seconds": 10 }
  ]
}
